{
  "name": "qrmenu-order",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset:dev": "prisma migrate reset --force --skip-generate",
    "pii:backfill": "ts-node -r tsconfig-paths/register -P tsconfig.scripts.json scripts/backfill-pii-legacy.ts",
    "pii:backfill:write": "ts-node -r tsconfig-paths/register -P tsconfig.scripts.json scripts/backfill-pii-legacy.ts --write",
    "secrets:backfill": "ts-node -P tsconfig.scripts.json scripts/backfill-encrypted-secrets.ts --dry-run",
    "secrets:backfill:write": "ts-node -P tsconfig.scripts.json scripts/backfill-encrypted-secrets.ts --write",
    "secrets:verify": "ts-node -P tsconfig.scripts.json scripts/verify-encrypted-secrets.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@codemirror/lang-html": "^6.4.11",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@number-flow/react": "^0.6.0",
    "@prisma/client": "^6.4.1",
    "@tiptap/extension-character-count": "^3.20.5",
    "@tiptap/extension-code-block-lowlight": "^3.20.5",
    "@tiptap/extension-horizontal-rule": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@uiw/react-codemirror": "^4.25.9",
    "dotenv": "^17.3.1",
    "iyzipay": "^2.0.65",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "redis": "^4.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.4.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
