# Örnek ortam değişkenleri — değerleri doldurun; bu dosyaya gerçek secret yazmayın.
# Kopyala: cp .env.example .env  (veya .env.local)

# Veritabanı (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Yönetici oturumu (uzun rastgele string)
ADMIN_SESSION_SECRET=

# Ödeme secret şifreleme (32 bayt: hex 64 karakter veya base64:...)
TENANT_PAYMENT_SECRET_KEY=
# Sadece secrets:backfill re-key: rotasyon öncesi eski anahtar (değer asla commit edilmez)
# TENANT_PAYMENT_SECRET_KEY_PREVIOUS=

# Sadece local dev: anahtar yokken geçici fallback (production’da yok sayılır; asla true bırakmayın)
ALLOW_DEV_PAYMENT_SECRET_FALLBACK=false

# Opsiyonel: prod’da DB’de legacy/plain secret var mı kontrolü (true/false)
PAYMENT_SECRET_STARTUP_CHECK=false

# Redis (RATE_LIMIT_STORE=redis iken)
REDIS_URL=
REDIS_PREFIX=
RATE_LIMIT_STORE=memory

# Uygulama URL (callback / origin kontrolleri)
APP_URL=
APP_BASE_URL=
NEXT_PUBLIC_APP_URL=
# Örn: "example.com,app.example.com" (prod’da zorunlu önerilir)
ALLOWED_APP_HOSTS=

# Iyzico
IYZIPAY_API_KEY=
IYZIPAY_SECRET_KEY=
# İsteğe bağlı; boşsa ortam (sandbox/prod) URI seçilir
IYZIPAY_URI=

# Geliştirme / özel
# ALLOW_LEGACY_ADMIN_USER_TENANT_LOGIN=true

# Google reCAPTCHA (Landing Lead Form)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Draft preview token security
PREVIEW_TOKEN_SECRET=
# Optional (default: 72)
PREVIEW_TOKEN_TTL_HOURS=72
