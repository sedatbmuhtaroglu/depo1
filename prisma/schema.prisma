generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanCode {
  MINI
  RESTAURANT
  CORPORATE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum FeatureCode {
  MENU
  WAITER_CALL
  ORDERING
  CUSTOM_DOMAIN
  INVOICING
  ADVANCED_REPORTS
  KITCHEN_DISPLAY
  ANALYTICS
}

enum LimitResource {
  USERS
  TABLES
  MENUS
  PRODUCTS
  BRANCHES
  DEVICES
}

enum SalesLeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  TRIAL_STARTED
  WON
  LOST
}

enum SalesLeadSource {
  INSTAGRAM
  WEBSITE
  REFERRAL
  MANUAL
  DEMO
  OTHER
}

enum MarketingSubmissionSource {
  LANDING_HOMEPAGE
  LANDING_CTA
  LANDING_FOOTER
}

enum MarketingSubmissionStatus {
  RECEIVED
  LEAD_CREATED
  LEAD_CREATE_FAILED
  SPAM_REJECTED
}

enum CommercialSaleType {
  DIRECT_PURCHASE
  TRIAL_CONVERSION
}

enum CommercialPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum CommercialOperationalStatus {
  DRAFT
  WON
  CANCELLED
}

enum CommercialPaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum ThemeColor {
  primary
  secondary
}

enum Language {
  TR
  EN
}

enum OrderStatus {
  PENDING_WAITER_APPROVAL
  PENDING
  PREPARING
  COMPLETED
  REJECTED
}

enum WaiterCallStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}

enum BillRequestStatus {
  PENDING
  ACKNOWLEDGED
  SETTLED
  CANCELED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  SODEXO
  MULTINET
  TICKET
  METROPOL
}

enum CancellationReason {
  CUSTOMER_CHANGED_MIND
  OUT_OF_STOCK
  WRONG_ITEM
  OTHER
}

enum StaffRole {
  MANAGER
  WAITER
  KITCHEN
}

enum PaymentGatewayProvider {
  IYZICO
}

enum PaymentIntentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum OrderPaymentStatus {
  PENDING
  INITIATED
  PAID
  FAILED
}

enum OrderRefundStatus {
  NONE
  REFUND_PENDING
  REFUNDED
  REFUND_FAILED
}

enum CashOrderAdjustmentType {
  PARTIAL_CANCEL
  PARTIAL_RETURN
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

/// Popüler vitrin otomatik kaydırma hızı (müdür paneli).
enum MenuShowcaseAutoplaySpeed {
  SLOW
  NORMAL
}

/// Sık tüketilenler vitrininin müşteri menüsundaki konumu.
enum MenuFrequentShowcasePlacement {
  ABOVE_CATEGORIES
  BELOW_CATEGORIES
  STICKY
  BLOCK
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Plan {
  id           Int      @id @default(autoincrement())
  name         String
  code         PlanCode @unique
  priceMonthly Decimal? @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants      Tenant[]
  planFeatures PlanFeature[]
}

model Tenant {
  id             Int          @id @default(autoincrement())
  name           String
  slug           String       @unique
  status         TenantStatus @default(ACTIVE)
  planId         Int
  setupCompleted Boolean      @default(false)
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  plan                   Plan                    @relation(fields: [planId], references: [id], onDelete: Restrict)
  domains                TenantDomain[]
  features               TenantFeature[]
  limitOverrides         TenantLimitOverride[]
  setupProgress          SetupProgress?
  restaurants            Restaurant[]
  tableSessions          TableSession[]
  waiterCalls            WaiterCall[]
  billRequests           BillRequest[]
  payments               Payment[]
  orderItemCancellations OrderItemCancellation[]
  staff                  TenantStaff[]
  auditLogs              AuditLog[]
  paymentIntents         PaymentIntent[]
  paymentConfigs         TenantPaymentConfig[]
  paymentMethods         TenantPaymentMethod[]
  menus                  Menu[]
  securityEvents         SecurityEvent[]
  cashOrderAdjustments   CashOrderAdjustment[]
  menuPopularShowcases   MenuPopularShowcase[]
  menuFrequentShowcases  MenuFrequentShowcase[]
  salesLeads             SalesLead[]
  commercialRecord       CommercialRecord?
}

model TenantLimitOverride {
  id        Int           @id @default(autoincrement())
  tenantId  Int
  resource  LimitResource
  limit     Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, resource])
  @@index([tenantId])
}

model TenantStaff {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  username     String
  passwordHash String
  mustSetPassword       Boolean   @default(true)
  passwordInitializedAt DateTime?
  role         StaffRole
  displayName  String?
  email        String?   @db.VarChar(180)
  phone        String?   @db.VarChar(32)
  isActive     Boolean   @default(true)
  workingDays  Weekday[] @default([])
  shiftStart   String?   @db.VarChar(5)
  shiftEnd     String?   @db.VarChar(5)
  /// Haftalık vardiya: [{ dayOfWeek, enabled, startTime, endTime }, ...] — dolu ise önceliklidir; yoksa workingDays+shift* legacy.
  weeklyShiftSchedule Json?
  notes        String?   @db.VarChar(280)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant                   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  acknowledgedWaiterCalls  WaiterCall[]          @relation("WaiterCallAcknowledgedBy")
  acknowledgedBillRequests BillRequest[]         @relation("BillRequestAcknowledgedBy")
  deliveredOrders          Order[]               @relation("OrderDeliveredBy")
  cashOrderAdjustments     CashOrderAdjustment[]
  setPasswordTokens        StaffSetPasswordToken[]

  @@unique([tenantId, username])
  @@index([tenantId])
}

model StaffSetPasswordToken {
  id               Int       @id @default(autoincrement())
  tenantStaffId    Int
  tokenHash        String    @unique @db.VarChar(64)
  expiresAt        DateTime
  consumedAt       DateTime?
  revokedAt        DateTime?
  createdBy        String?   @db.VarChar(120)
  createdAt        DateTime  @default(now())

  tenantStaff TenantStaff @relation(fields: [tenantStaffId], references: [id], onDelete: Cascade)

  @@index([tenantStaffId, createdAt])
  @@index([tenantStaffId, consumedAt, revokedAt, expiresAt])
}

model TenantDomain {
  id         Int        @id @default(autoincrement())
  tenantId   Int
  domain     String
  isPrimary  Boolean    @default(false)
  isVerified Boolean    @default(false)
  type       DomainType
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, domain])
}

model TenantPaymentConfig {
  id        Int                    @id @default(autoincrement())
  tenantId  Int
  provider  PaymentGatewayProvider
  apiKey    String?
  secretKey String?
  isSandbox Boolean                @default(true)
  isActive  Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model TenantPaymentMethod {
  id       Int           @id @default(autoincrement())
  tenantId Int
  method   PaymentMethod
  isActive Boolean       @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, method])
  @@index([tenantId])
}

model Feature {
  id          Int         @id @default(autoincrement())
  code        FeatureCode @unique
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  planFeatures    PlanFeature[]
  tenantOverrides TenantFeature[]
}

model PlanFeature {
  planId    Int
  featureId Int

  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
}

model TenantFeature {
  tenantId  Int
  featureId Int
  enabled   Boolean @default(true)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([tenantId, featureId])
}

model SetupProgress {
  tenantId              Int       @unique
  currentStep           String
  businessInfoCompleted Boolean   @default(false)
  branchSetupCompleted  Boolean   @default(false)
  tablesSetupCompleted  Boolean   @default(false)
  menuSetupCompleted    Boolean   @default(false)
  domainSetupCompleted  Boolean   @default(false)
  completedAt           DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SalesLead {
  id          Int             @id @default(autoincrement())
  businessName String
  contactName String
  phone       String?         @db.VarChar(32)
  email       String?         @db.VarChar(180)
  city        String?         @db.VarChar(120)
  notes       String?
  source      SalesLeadSource @default(MANUAL)
  status      SalesLeadStatus @default(NEW)
  assignedTo  String?         @db.VarChar(120)
  lostReason  String?         @db.VarChar(280)
  tenantId    Int?
  trialStartedAt DateTime?
  trialEndsAt DateTime?
  trialAdminUsername String?  @db.VarChar(120)
  wonAt       DateTime?
  lostAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  events SalesLeadEvent[]
  commercialRecord CommercialRecord?
  marketingSubmissions MarketingFormSubmission[]

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([tenantId])
  @@index([email])
}

model MarketingSiteConfig {
  id                        Int      @id @default(autoincrement())
  key                       String   @unique @default("main")
  isPublished               Boolean  @default(true)
  brandName                 String   @default("MENUCY")
  brandTagline              String?  @db.VarChar(180)
  announcementEnabled       Boolean  @default(false)
  announcementText          String?  @db.VarChar(240)
  announcementCtaLabel      String?  @db.VarChar(80)
  announcementCtaHref       String?  @db.VarChar(220)
  heroKicker                String?  @db.VarChar(120)
  heroTitle                 String   @db.VarChar(180)
  heroDescription           String   @db.VarChar(600)
  heroPrimaryCtaLabel       String   @db.VarChar(80)
  heroPrimaryCtaHref        String   @db.VarChar(220)
  heroSecondaryCtaLabel     String?  @db.VarChar(80)
  heroSecondaryCtaHref      String?  @db.VarChar(220)
  trustSectionTitle         String?  @db.VarChar(120)
  trustSectionDescription   String?  @db.VarChar(320)
  featuresSectionTitle      String?  @db.VarChar(120)
  featuresSectionDescription String? @db.VarChar(320)
  howItWorksSectionTitle    String?  @db.VarChar(120)
  howItWorksSectionDescription String? @db.VarChar(320)
  categorySectionTitle      String?  @db.VarChar(120)
  categorySectionDescription String? @db.VarChar(320)
  ctaSectionTitle           String?  @db.VarChar(140)
  ctaSectionDescription     String?  @db.VarChar(320)
  ctaPrimaryLabel           String?  @db.VarChar(80)
  ctaPrimaryHref            String?  @db.VarChar(220)
  faqSectionTitle           String?  @db.VarChar(120)
  faqSectionDescription     String?  @db.VarChar(320)
  formSectionTitle          String   @db.VarChar(140)
  formSectionDescription    String?  @db.VarChar(320)
  formSubmitLabel           String   @db.VarChar(80)
  formConsentText           String?  @db.VarChar(280)
  seoTitle                  String?  @db.VarChar(160)
  seoDescription            String?  @db.VarChar(320)
  seoCanonicalUrl           String?  @db.VarChar(320)
  seoOgTitle                String?  @db.VarChar(160)
  seoOgDescription          String?  @db.VarChar(320)
  seoOgImageUrl             String?  @db.VarChar(320)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  trustBadges   MarketingTrustBadge[]
  logos         MarketingLogo[]
  features      MarketingFeature[]
  howItWorks    MarketingHowItWorksStep[]
  categories    MarketingCategory[]
  faqs          MarketingFaq[]
  submissions   MarketingFormSubmission[]
}

model MarketingTrustBadge {
  id           Int      @id @default(autoincrement())
  siteConfigId Int
  label        String   @db.VarChar(120)
  sublabel     String?  @db.VarChar(220)
  iconName     String?  @db.VarChar(64)
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig MarketingSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId, sortOrder])
}

model MarketingLogo {
  id           Int      @id @default(autoincrement())
  siteConfigId Int
  name         String   @db.VarChar(120)
  logoUrl      String   @db.VarChar(320)
  targetUrl    String?  @db.VarChar(320)
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig MarketingSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId, sortOrder])
}

model MarketingFeature {
  id           Int      @id @default(autoincrement())
  siteConfigId Int
  title        String   @db.VarChar(140)
  description  String   @db.VarChar(420)
  iconName     String?  @db.VarChar(64)
  ctaLabel     String?  @db.VarChar(80)
  ctaHref      String?  @db.VarChar(220)
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig MarketingSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId, sortOrder])
}

model MarketingHowItWorksStep {
  id           Int      @id @default(autoincrement())
  siteConfigId Int
  title        String   @db.VarChar(140)
  description  String   @db.VarChar(420)
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig MarketingSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId, sortOrder])
}

model MarketingCategory {
  id           Int      @id @default(autoincrement())
  siteConfigId Int
  slug         String   @db.VarChar(64)
  title        String   @db.VarChar(140)
  description  String?  @db.VarChar(320)
  iconName     String?  @db.VarChar(64)
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig    MarketingSiteConfig    @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)
  subcategories MarketingSubcategory[]

  @@unique([siteConfigId, slug])
  @@index([siteConfigId, sortOrder])
}

model MarketingSubcategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  slug        String   @db.VarChar(64)
  title       String   @db.VarChar(140)
  description String?  @db.VarChar(320)
  ctaLabel    String?  @db.VarChar(80)
  ctaHref     String?  @db.VarChar(220)
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category MarketingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

model MarketingFaq {
  id           Int      @id @default(autoincrement())
  siteConfigId Int
  question     String   @db.VarChar(220)
  answer       String
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig MarketingSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId, sortOrder])
}

model MarketingFormSubmission {
  id            Int                        @id @default(autoincrement())
  siteConfigId  Int?
  source        MarketingSubmissionSource  @default(LANDING_HOMEPAGE)
  status        MarketingSubmissionStatus  @default(RECEIVED)
  contactName   String                     @db.VarChar(120)
  businessName  String                     @db.VarChar(160)
  phone         String?                    @db.VarChar(32)
  email         String?                    @db.VarChar(180)
  city          String?                    @db.VarChar(120)
  message       String?
  consentGiven  Boolean                    @default(false)
  utmSource     String?                    @db.VarChar(120)
  utmMedium     String?                    @db.VarChar(120)
  utmCampaign   String?                    @db.VarChar(120)
  utmTerm       String?                    @db.VarChar(120)
  utmContent    String?                    @db.VarChar(120)
  landingPath   String?                    @db.VarChar(220)
  referrer      String?                    @db.VarChar(320)
  ipHash        String?                    @db.VarChar(128)
  userAgentHash String?                    @db.VarChar(128)
  leadId        Int?
  failureReason String?                    @db.VarChar(280)
  processedAt   DateTime?
  createdAt     DateTime                   @default(now())

  siteConfig MarketingSiteConfig? @relation(fields: [siteConfigId], references: [id], onDelete: SetNull)
  lead       SalesLead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([leadId])
  @@index([source, createdAt])
}

model CommercialRecord {
  id                  Int                         @id @default(autoincrement())
  leadId              Int                         @unique
  tenantId            Int?                        @unique
  saleType            CommercialSaleType
  planCode            PlanCode?
  packageName         String?                     @db.VarChar(120)
  currency            String                      @db.VarChar(3)
  listPrice           Decimal                     @db.Decimal(12, 2)
  discountAmount      Decimal                     @db.Decimal(12, 2)
  netSaleAmount       Decimal                     @db.Decimal(12, 2)
  amountCollected     Decimal                     @default(0) @db.Decimal(12, 2)
  remainingBalance    Decimal                     @db.Decimal(12, 2)
  paymentStatus       CommercialPaymentStatus     @default(UNPAID)
  operationalStatus   CommercialOperationalStatus @default(DRAFT)
  paymentMethodSummary String?                    @db.VarChar(280)
  dueDate             DateTime?
  soldAt              DateTime
  salespersonName     String?                     @db.VarChar(120)
  notes               String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  lead     SalesLead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant   Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  payments SalePayment[]

  @@index([tenantId])
  @@index([paymentStatus, operationalStatus])
}

model SalePayment {
  id                 Int                     @id @default(autoincrement())
  commercialRecordId Int
  amount             Decimal                 @db.Decimal(12, 2)
  currency           String                  @db.VarChar(3)
  paymentMethod      CommercialPaymentMethod
  paidAt             DateTime
  note               String?                 @db.VarChar(280)
  createdAt          DateTime                @default(now())

  commercialRecord CommercialRecord @relation(fields: [commercialRecordId], references: [id], onDelete: Cascade)

  @@index([commercialRecordId, paidAt])
}

model SalesLeadEvent {
  id            Int      @id @default(autoincrement())
  leadId         Int
  actorUsername  String   @db.VarChar(120)
  actionType     String   @db.VarChar(80)
  description    String?
  createdAt      DateTime @default(now())

  lead SalesLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model Restaurant {
  id                         Int        @id @default(autoincrement())
  tenantId                   Int?
  name                       String
  slug                       String     @unique
  logoUrl                    String?
  themeColor                 ThemeColor
  menuFontSizePx             Int?
  menuTextColor              String?    @db.VarChar(7)
  menuBackgroundColor        String?    @db.VarChar(7)
  menuButtonBackgroundColor  String?    @db.VarChar(7)
  menuHeaderBackgroundColor  String?    @db.VarChar(7)
  language                   Language   @default(TR)
  /// Günlük çalışma başlangıç saati (örn: 09:00). İleride ayrı bir ayar tablosuna taşınabilir.
  openingHour                String?    @db.VarChar(5)
  /// Günlük çalışma bitiş saati (örn: 23:30).
  closingHour                String?    @db.VarChar(5)
  /// Siparişe genel kapama bayrağı (bakım vb. için kullanılabilir).
  orderingDisabled           Boolean    @default(false)
  /// Musteri siparisi icin konum dogrulamasi zorunlu mu.
  locationEnforcementEnabled Boolean    @default(false)
  /// Siparis verebilmek icin izin verilen maksimum mesafe (metre).
  orderRadiusMeters          Int        @default(100)
  /// Restoran konumu enlemi (WGS84).
  locationLatitude           Decimal?   @db.Decimal(10, 7)
  /// Restoran konumu boylami (WGS84).
  locationLongitude          Decimal?   @db.Decimal(10, 7)
  /// Mutfak bekleme uyarı eşiği: sarı (dakika)
  kitchenWarningYellowMin    Int?
  /// Mutfak bekleme uyarı eşiği: turuncu (dakika)
  kitchenWarningOrangeMin    Int?
  /// Mutfak bekleme uyarı eşiği: kırmızı (dakika)
  kitchenWarningRedMin       Int?

  tenant       Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  categories   Category[]
  menus        Menu[]
  tables       Table[]
  workingHours RestaurantWorkingHour[]
}

model RestaurantWorkingHour {
  id           Int     @id @default(autoincrement())
  restaurantId Int
  weekday      Weekday
  isOpen       Boolean @default(true)
  openTime     String? @db.VarChar(5)
  closeTime    String? @db.VarChar(5)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, weekday])
  @@index([restaurantId])
}

model Menu {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  restaurantId Int?
  name         String
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  restaurant        Restaurant?            @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  categories        Category[]
  popularShowcases  MenuPopularShowcase[]
  frequentShowcase  MenuFrequentShowcase?

  @@index([tenantId])
  @@index([restaurantId])
}

model Category {
  id           Int     @id @default(autoincrement())
  restaurantId Int
  menuId       Int?
  nameTR       String
  nameEN       String?

  restaurant         Restaurant              @relation(fields: [restaurantId], references: [id])
  menu               Menu?                   @relation(fields: [menuId], references: [id], onDelete: SetNull)
  products           Product[]
  menuPopularShowcases MenuPopularShowcase[]

  @@index([restaurantId])
  @@index([menuId])
}

model Product {
  id            Int      @id @default(autoincrement())
  categoryId    Int
  nameTR        String
  nameEN        String?
  descriptionTR String?
  descriptionEN String?
  price         Decimal  @db.Decimal(10, 2)
  imageUrl      String?
  isAvailable   Boolean  @default(true)
  /// Menü görünürlüğü (stoktan bağımsız). İleride modül-limit / yetenek kontrolleri bu alanla birlikte
  /// merkezi helper'a bağlanacak şekilde tasarlanmıştır.
  isActive      Boolean  @default(true)
  /// Opsiyonel zaman penceresi: bu aralık dışındaysa ürün menüde gizli kalır.
  visibleFrom   DateTime?
  visibleUntil  DateTime?
  /// Kategori içinde öne çıkarma + sıralama.
  isFeatured    Boolean  @default(false)
  sortOrder     Int      @default(0)
  trackStock    Boolean  @default(false)
  stockQuantity Int      @default(0)
  updatedAt     DateTime @updatedAt
  /// Ürün etiketleri (örn: yemek, içecek, tatlı). Faz-1 için basit JSON dizi.
  tags          Json?
  /// Ürün seçenekleri (boyut, pişme derecesi vb.). Faz-1 için basit JSON dizi.
  options       Json?

  category              Category                  @relation(fields: [categoryId], references: [id])
  optionGroups          ProductOptionGroup[]
  orderItemOptions      OrderItemOption[]
  popularShowcaseItems  MenuPopularShowcaseItem[]
  frequentShowcaseItems MenuFrequentShowcaseItem[]

  @@index([categoryId])
}

/// Kategori görünümünde yatay vitrin: yalnızca ilgili kategorideyken storefront’ta gösterilir.
model MenuPopularShowcase {
  id              Int                       @id @default(autoincrement())
  tenantId        Int
  menuId          Int
  categoryId      Int
  title           String                    @db.VarChar(160)
  subtitle        String?                   @db.VarChar(320)
  isEnabled       Boolean                   @default(false)
  /// Otomatik yatay kaydırma (prefers-reduced-motion her zaman baskın çıkar).
  autoplayEnabled Boolean                   @default(false)
  autoplaySpeed   MenuShowcaseAutoplaySpeed @default(SLOW)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  tenant   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menu     Menu                      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  category Category                  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    MenuPopularShowcaseItem[]

  @@unique([menuId, categoryId])
  @@index([tenantId])
  @@index([menuId])
}

model MenuPopularShowcaseItem {
  id         Int @id @default(autoincrement())
  showcaseId Int
  productId  Int
  sortOrder  Int @default(0)

  showcase MenuPopularShowcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  product  Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([showcaseId, productId])
  @@index([showcaseId])
}

/// Menü genelinde, kategori değişse de görünen vitrin.
model MenuFrequentShowcase {
  id        Int                          @id @default(autoincrement())
  tenantId  Int
  menuId    Int                          @unique
  title     String                       @db.VarChar(160)
  subtitle  String?                      @db.VarChar(320)
  isEnabled Boolean                      @default(false)
  placement MenuFrequentShowcasePlacement @default(BELOW_CATEGORIES)
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  tenant Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menu   Menu                         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items  MenuFrequentShowcaseItem[]

  @@index([tenantId])
}

model MenuFrequentShowcaseItem {
  id         Int @id @default(autoincrement())
  showcaseId Int
  productId  Int
  sortOrder  Int @default(0)

  showcase MenuFrequentShowcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  product  Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([showcaseId, productId])
  @@index([showcaseId])
}

model Table {
  id           Int     @id @default(autoincrement())
  restaurantId Int
  tableNo      Int
  qrCode       String
  publicCode   String  @unique
  isActive     Boolean @default(false)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]
  payments   Payment[]

  sessions       TableSession[]
  waiterCalls    WaiterCall[]
  billRequests   BillRequest[]
  securityEvents SecurityEvent[]

  @@index([restaurantId])
}

model TableSession {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  tableId      Int
  sessionToken String   @unique
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Son sipariş oluşturma denemesinin zamanı (kalıcı anti-spam için)
  lastOrderAttemptAt DateTime?

  /// İleride eklenecek garson çağırma (waiter call) aksiyonları için
  /// son istek zamanı. Şimdilik yalnızca veri modeli seviyesinde hazırlanıyor.
  lastWaiterCallAt DateTime?

  /// Bu masa oturumu için biriken spam puanı.
  /// Yüksek frekansta tekrar denemelerde artar, normal kullanımda yumuşakça azalır.
  spamStrike Int @default(0)

  /// Oturum geçici olarak bloklandıysa, blok bitiş zamanı.
  blockedUntil DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table  Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  billRequests   BillRequest[]
  securityEvents SecurityEvent[]

  @@index([tenantId, tableId])
}

model Order {
  id                     Int                     @id @default(autoincrement())
  tableId                Int
  items                  Json
  totalPrice             Decimal                 @db.Decimal(10, 2)
  requestedPaymentMethod PaymentMethod?
  paymentProvider        PaymentGatewayProvider?
  paymentStatus          OrderPaymentStatus?
  refundStatus           OrderRefundStatus       @default(NONE)
  refundedAt             DateTime?
  refundReference        String?                 @db.VarChar(191)
  refundFailureReason    String?                 @db.VarChar(512)
  paymentReference       String?                 @db.VarChar(191)
  paymentConversationId  String?                 @db.VarChar(191)
  status                 OrderStatus             @default(PENDING_WAITER_APPROVAL)
  isRiskFlagged          Boolean                 @default(false)
  riskScore              Int                     @default(0)
  riskLevel              String?                 @db.VarChar(16)
  riskReasons            Json?
  createdAt              DateTime                @default(now())
  /// Müşteri veya garson notu.
  note                   String?
  /// Siparişin ilk kez hazırlanıyor durumuna geçtiği an.
  preparingStartedAt     DateTime?
  readyAt                DateTime?
  deliveredAt            DateTime?
  deliveredByStaffId     Int?

  table                  Table                   @relation(fields: [tableId], references: [id])
  deliveredByStaff       TenantStaff?            @relation("OrderDeliveredBy", fields: [deliveredByStaffId], references: [id], onDelete: SetNull)
  orderItemCancellations OrderItemCancellation[]
  cashAdjustments        CashOrderAdjustment[]
  itemOptions            OrderItemOption[]

  @@index([tableId])
  @@index([status, createdAt])
  @@index([isRiskFlagged, createdAt])
}

model ProductOptionGroup {
  id         Int     @id @default(autoincrement())
  productId  Int
  nameTR     String
  nameEN     String?
  /// Minimum kaç seçim zorunlu (0 = opsiyonel)
  minSelect  Int     @default(0)
  /// Maksimum kaç seçim yapılabilir (null = sınırsız)
  maxSelect  Int?
  isRequired Boolean @default(false)
  sortOrder  Int     @default(0)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductOption[]

  @@index([productId])
}

model ProductOption {
  id         Int      @id @default(autoincrement())
  groupId    Int
  nameTR     String
  nameEN     String?
  /// Seçenek için fiyat farkı (örn: +5 TL). Null veya 0 = fark yok.
  priceDelta Decimal? @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)

  group            ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemOption[]

  @@index([groupId])
}

model OrderItemOption {
  id        Int @id @default(autoincrement())
  orderId   Int
  productId Int
  optionId  Int
  quantity  Int @default(1)

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  option  ProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([optionId])
}

model Payment {
  id               Int                     @id @default(autoincrement())
  tenantId         Int
  tableId          Int
  billRequestId    Int?
  amount           Decimal                 @db.Decimal(10, 2)
  method           PaymentMethod
  note             String?
  gatewayProvider  PaymentGatewayProvider?
  gatewayPaymentId String?
  createdAt        DateTime                @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table       Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  billRequest BillRequest? @relation(fields: [billRequestId], references: [id], onDelete: SetNull)

  @@unique([tenantId, gatewayProvider, gatewayPaymentId])
  @@index([tenantId, tableId])
  @@index([tenantId, createdAt])
}

model PaymentIntent {
  id              Int                    @id @default(autoincrement())
  tenantId        Int
  billRequestId   Int
  amount          Decimal                @db.Decimal(10, 2)
  currency        String                 @db.VarChar(3)
  gatewayToken    String                 @unique
  gatewayProvider PaymentGatewayProvider
  status          PaymentIntentStatus    @default(PENDING)
  createdAt       DateTime               @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billRequest BillRequest @relation(fields: [billRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([gatewayToken])
}

model OrderItemCancellation {
  id           Int                @id @default(autoincrement())
  tenantId     Int
  orderId      Int
  productId    Int
  quantity     Int
  reason       CancellationReason
  customReason String?
  performedBy  String? /// Şimdilik serbest metin; ileride personel tablosuna bağlanabilir.
  createdAt    DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@index([tenantId, createdAt])
}

model CashOrderAdjustment {
  id                Int                     @id @default(autoincrement())
  tenantId          Int
  orderId           Int
  orderItemId       Int?
  productId         Int
  adjustedQuantity  Int
  unitPriceSnapshot Decimal                 @db.Decimal(10, 2)
  totalAmountDelta  Decimal                 @db.Decimal(10, 2)
  reason            String?                 @db.VarChar(512)
  actionType        CashOrderAdjustmentType
  actorUserId       Int?
  createdAt         DateTime                @default(now())

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor  TenantStaff? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
}

model WaiterCall {
  id                    Int              @id @default(autoincrement())
  tenantId              Int
  tableId               Int
  status                WaiterCallStatus @default(PENDING)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  resolvedAt            DateTime?
  /// İlk yanıt (ACKNOWLEDGED) anı
  acknowledgedAt        DateTime?
  acknowledgedByStaffId Int?

  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table               Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  acknowledgedByStaff TenantStaff? @relation("WaiterCallAcknowledgedBy", fields: [acknowledgedByStaffId], references: [id], onDelete: SetNull)

  @@index([tenantId, tableId])
  @@index([tenantId, createdAt])
}

model BillRequest {
  id                    Int               @id @default(autoincrement())
  tenantId              Int
  tableId               Int
  tableSessionId        Int?
  status                BillRequestStatus @default(PENDING)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  settledAt             DateTime?
  acknowledgedAt        DateTime?
  acknowledgedByStaffId Int?

  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table               Table           @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableSession        TableSession?   @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)
  acknowledgedByStaff TenantStaff?    @relation("BillRequestAcknowledgedBy", fields: [acknowledgedByStaffId], references: [id], onDelete: SetNull)
  payments            Payment[]
  paymentIntents      PaymentIntent[]

  @@index([tenantId, tableId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, tableId, status])
  @@index([tenantId, tableSessionId, status])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  actorType   String   @db.VarChar(20)
  actorId     String?  @db.VarChar(128)
  role        String?  @db.VarChar(20)
  actionType  String   @db.VarChar(64)
  entityType  String   @db.VarChar(32)
  entityId    String?  @db.VarChar(64)
  description String?  @db.VarChar(512)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, actionType])
}

model SecurityEvent {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  tableId         Int?
  tableSessionId  Int?
  actionType      String   @db.VarChar(64)
  outcome         String   @db.VarChar(16)
  riskScore       Int      @default(0)
  riskLevel       String?  @db.VarChar(16)
  reasons         Json?
  ipHash          String?  @db.VarChar(128)
  fingerprintHash String?  @db.VarChar(128)
  userAgentHash   String?  @db.VarChar(128)
  clientTimezone  String?  @db.VarChar(64)
  clientLat       Decimal? @db.Decimal(10, 7)
  clientLng       Decimal? @db.Decimal(10, 7)
  clientAccuracyM Decimal? @db.Decimal(10, 2)
  ipCountry       String?  @db.VarChar(8)
  ipCity          String?  @db.VarChar(64)
  ipTimezone      String?  @db.VarChar(64)
  ipRiskLevel     String?  @db.VarChar(16)
  ipRiskProvider  String?  @db.VarChar(32)
  meta            Json?
  createdAt       DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table        Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableSession TableSession? @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, actionType, createdAt])
  @@index([fingerprintHash, createdAt])
  @@index([ipHash, createdAt])
}
